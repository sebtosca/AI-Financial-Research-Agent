# Application
APP_NAME=Financial Research Agent
APP_HOST=127.0.0.1
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
DEBUG=false

# Local persistence
# Leave DATABASE_URL empty to use SQLite when running Uvicorn on the host.
RUN_STORE_PATH=./data/research_history.sqlite3
DATABASE_URL=
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=10
DATABASE_POOL_TIMEOUT=30

# Durable worker queue
# Leave REDIS_URL empty to run agent execution in-process (single replica,
# same as before) instead of on a separate arq worker.
REDIS_URL=
WORKER_CONCURRENCY=10

# OpenAI
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0
EMBEDDING_MODEL=text-embedding-3-small

# Multi-provider selection (openai | anthropic | google)
# Anthropic/Google require: pip install -r requirements-optional.txt
CHAT_PROVIDER=openai
EMBEDDING_PROVIDER=openai
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=
GOOGLE_API_KEY=

# Per-tool provider/model overrides (default to the CHAT_PROVIDER/OPENAI_MODEL above)
SENTIMENT_PROVIDER=
SENTIMENT_MODEL=
SENTIMENT_TEMPERATURE=
PRIVATE_DATABASE_PROVIDER=

# Policy-based routing
ROUTING_ENABLED=true
ROUTING_FAST_PROVIDER=openai
ROUTING_FAST_MODEL=gpt-4o-mini
ROUTING_CAPABLE_PROVIDER=openai
ROUTING_CAPABLE_MODEL=gpt-4o

# Tavily
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=advanced
TAVILY_INCLUDE_ANSWER=true
TAVILY_INCLUDE_RAW_CONTENT=false
TAVILY_INCLUDE_IMAGES=false

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=financial-research-agent
LANGSMITH_FEEDBACK_ENABLED=

# RAG documents and indexing
DOCS_PATH=./app/docs
ZIP_FILE=./docs/Companies-AI-Initiatives.zip
TEXT_SPLITTER_ENCODING=cl100k_base
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHROMA_COLLECTION_NAME=ai_initiatives
CHROMA_DB_DIR=./chroma_db
RAG_REBUILD_INDEX=false
RETRIEVER_TOP_K=10
RETRIEVER_SEARCH_TYPE=similarity

# Private analyst database tool
PRIVATE_DATABASE_MODEL=gpt-4o-mini
PRIVATE_DATABASE_TEMPERATURE=0
PRIVATE_DATABASE_MAX_QUERY_CHARS=2000
PRIVATE_DATABASE_MAX_CONTEXT_CHARS=20000
PRIVATE_DATABASE_REQUEST_TIMEOUT=30
PRIVATE_DATABASE_MAX_RETRIES=2
PRIVATE_DATABASE_NO_RESULTS_MESSAGE=I don't know - this information is not available in our analyst reports.
PRIVATE_DATABASE_ERROR_MESSAGE=The private analyst database is temporarily unavailable.

# Tool defaults
STOCK_HISTORY_DEFAULT_PERIOD=1y

# Docker Compose PostgreSQL
# Compose constructs DATABASE_URL with these values inside the Docker network.
POSTGRES_DB=financial_research
POSTGRES_USER=financial_agent
POSTGRES_PASSWORD=change-me

# Docker Compose Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
